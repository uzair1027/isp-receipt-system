{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "vite",
      "environment": {
        "VITE_API_URL": "/api/v1"
      }
    },
    "backend": {
      "root": "backend",
      "entrypoint": "app/main.py",
      "environment": {
        "SECRET_KEY": "a3f8b2c1d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0",
        "ALGORITHM": "HS256",
        "DATABASE_URL": "sqlite:///./isp_receipts.db",
        "CORS_ORIGINS": "*"
      }
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": {
        "type": "service",
        "service": "backend"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "frontend"
      }
    }
  ]
}
